# ---- Server ----
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ---- Database (local Postgres 17; swap for Supabase/hosted connection string) ----
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/researchhub

# ---- JWT ----
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Auth policy ----
ALLOWED_EMAIL_DOMAIN=unilag.edu.ng
# When true (dev), registration auto-verifies and prints the verify link instead of emailing.
AUTH_AUTO_VERIFY=true

# ---- Seed admin ----
SEED_ADMIN_EMAIL=admin@unilag.edu.ng
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=ARB Administrator

# ---- File storage ----
# STORAGE_DRIVER=local | s3 | supabase
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./uploads
# s3
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
# supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=papers

# ---- Email (Resend). If unset, links are printed to the console. ----
RESEND_API_KEY=
EMAIL_FROM=ARB ResearchHub <no-reply@unilag.edu.ng>

# ---- AI search (Groq) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Local embedding model (runs in-process, no key). 384 dims.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIM=384
