# ---- Server ----
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ---- Database ----
# Local:
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/researchhub
# Supabase pooler example. URL-encode special characters in the password, e.g. @ -> %40:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ---- JWT ----
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Auth policy ----
ALLOWED_EMAIL_DOMAIN=unilag.edu.ng

# ---- Seed admin ----
SEED_ADMIN_EMAIL=admin@unilag.edu.ng
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=ARB Administrator

# ---- File storage ----
# STORAGE_DRIVER=local | s3 | supabase
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./uploads
# s3
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
# supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=papers

# ---- Email (Resend) ----
# Password reset is disabled in production unless ENABLE_PASSWORD_RESET=true and RESEND_API_KEY is set.
ENABLE_PASSWORD_RESET=false
RESEND_API_KEY=
EMAIL_FROM=ARB ResearchHub <no-reply@unilag.edu.ng>

# ---- AI search (Groq) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Dependency-free semantic vectorizer. Keep this stable after launch unless you re-index papers.
EMBEDDING_MODEL=hashing-v1
EMBEDDING_DIM=384
WARM_EMBEDDINGS_ON_START=false
